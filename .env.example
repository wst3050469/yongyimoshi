# ============================================
# 永颐无机磨石 · 施工管理平台 v4.4.1
# 环境变量配置模板
# ============================================
# 使用方式: 复制为 .env 文件并修改配置
# cp .env.example .env

# ========== 必填 ==========
# Flask 密钥 - 用于 session 加密，请设置一个随机字符串
SECRET_KEY=your-secure-random-key-here-change-in-production

# ========== 可选 ==========
# 默认管理员密码（首次启动时创建，不设置则默认 admin123）
# DEFAULT_ADMIN_PWD=your-admin-password

# Flask 环境
# FLASK_ENV=production

# 数据库路径（默认 data/yongyi.db）
# DATABASE_PATH=data/yongyi.db

# ========== Webhook 通知 ==========
# 企业微信机器人 Webhook URL（在管理员页面配置更便捷）
# WECHAT_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx

# 钉钉机器人 Webhook URL
# DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=xxx

# ========== SEO ==========
# 百度统计 ID
# BAIDU_TONGJI_ID=

# 百度站长推送 Token（用于自动推送 sitemap）
# BAIDU_PUSH_TOKEN=
