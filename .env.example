# ============================================
# 永颐无机磨石 · 施工管理平台
# 环境变量配置模板
# ============================================
# 使用方式: 复制为 .env 文件并修改配置
# cp .env.example .env

# 【必填】Flask 密钥 - 用于 session 加密，请设置一个随机字符串
SECRET_KEY=your-secure-random-key-here-change-in-production

# 【可选】默认管理员密码（首次启动时创建）
# 如不设置，默认密码为 admin123（仅用于开发环境）
# DEFAULT_ADMIN_PWD=your-admin-password

# 【可选】Flask 环境
# FLASK_ENV=production

# 【可选】数据库路径（默认 data/yongyi.db）
# DATABASE_PATH=data/yongyi.db
